# Copy this file to .env and fill in real values. Never commit .env.

# Resend (email sending) — get from resend.com dashboard
RESEND_API_KEY=
FROM_EMAIL=hi@dozenko.io.vn

# GitHub-as-storage backup for brain.db (only needed if you don't have a
# persistent disk on the host — fine-grained PAT with Contents: Read & write)
GITHUB_TOKEN=
GITHUB_REPO=dtn-yoko/dozenko-store
GITHUB_BACKUP_BRANCH=db-backup

# Optional: override default payment link shown in emails
PAYMENT_LINK=

# Port the Flask app listens on (gunicorn also respects $PORT via Procfile)
PORT=5000

# MCP server (mcp_server.py) — exposes get_daily_summary, confirm_order_payment,
# check_low_stock as MCP tools over streamable-http for goClaw integration.
MCP_API_KEY=
MCP_PORT=8001
MCP_PUBLIC_HOST=mcp.dozenko.io.vn
CRM_API_BASE=http://127.0.0.1:8000
